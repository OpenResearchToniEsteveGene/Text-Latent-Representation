      "source": [
        "# Import libraries for numerical computation, statistics, and plotting\n",
        "\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import scipy.stats as stats\n",
        "import pandas as pd  # ← Required to create the final table\n",
        "\n",
        "# Actual AUC-ROC values for two models: TF-IDF and LDA\n",
        "# (each list contains the results for 5 cross-validation folds)\n",
        "\n",
        "auc_tfidf = [\n",
        "    0.9914700435601005,\n",
        "    0.9903283656763467,\n",
        "    0.9891287077837895,\n",
        "    0.9942759542752444,\n",
        "    0.9922045568934963]\n",
        "\n",
        "auc_lda = [\n",
        "    0.9640405288040741,\n",
        "    0.9694402047235843,\n",
        "    0.98127959001195,\n",
        "    0.9795027103225513,\n",
        "    0.9772453506913165]\n",
        "\n",
        "# Compute pairwise differences between LDA and TF-IDF\n",
        "# (to observe which model yields better results in each fold)\n",
        "\n",
        "differences = [a - b for a, b in zip(auc_lda, auc_tfidf)]\n",
        "\n",
        "# Q-Q Plot: graphical check of the normality of the differences\n",
        "# This plot compares the observed quantiles with those of a theoretical normal distribution\n",
        "\n",
        "plt.figure(figsize=(6, 6))\n",
        "stats.probplot(differences, dist=\"norm\", plot=plt)\n",
        "plt.title(\"Q-Q Plot of the differences (LDA - TF-IDF)\")\n",
        "plt.xlabel(\"Theoretical quantiles\")\n",
        "plt.ylabel(\"Observed quantiles\")\n",
        "plt.grid(True)\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 2,
      "id": "9325b110",
      "metadata": {},
      "outputs": [
        {
          "data": {
            "text/plain": [
              "(np.float64(-5.220503031816293), np.float64(0.006425258354856111))"
            ]
          },
          "execution_count": 2,
          "metadata": {},
          "output_type": "execute_result"
        }
      ],
      "source": [
        "\n",
        "# Compute the Student's paired t-test (ttest_rel)\n",
        "# Objective: to check whether the mean difference between LDA and TF-IDF is statistically significant\n",
        "\n",
        "from scipy.stats import ttest_rel\n",
        "\n",
        "\n",
        "# Apply the paired t-test to compare LDA vs TF-IDF\n",
        "t_statistic_real, p_value_real = ttest_rel(auc_lda, auc_tfidf)\n",
        "\n",
        "# Create a comparative table with the metrics and differences\n",
        "\n",
        "df_real = pd.DataFrame({\n",
        "    \"Fold\": list(range(1, 6)),  # Fold numbers\n",
        "    \"AUC_TFIDF\": auc_tfidf,  # TF-IDF results\n",
        "    \"AUC_LDA\": auc_lda,      # LDA results\n",
        "    \"Difference (LDA - TF-IDF)\": [a - b for a, b in zip(auc_lda, auc_tfidf)]\n",
        "})\n",
        "\n",
        "# Final result of the t-test\n",
        "# t_statistic_real: t-value\n",
        "# p_value_real: associated p-value (used to decide whether the difference is significant)\n",
        "\n",
        "t_statistic_real, p_value_real\n"
      ]
    }
  ],
